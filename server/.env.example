# Single key (legacy)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Multiple keys — comma-separated, auto-rotates on rate limit
# NVIDIA_API_KEYS=key1,key2,key3

# Primary model + fallbacks when all keys are busy on primary
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
# NVIDIA_FALLBACK_MODELS=meta/llama-3.1-8b-instruct,google/gemma-2-2b-it

PORT=3001
MAX_TOKENS=4096
KEY_COOLDOWN_MS=60000
